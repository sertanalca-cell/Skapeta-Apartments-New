# Production Environment Variables
# Copy this to .env.production and update with your values

# MongoDB Connection (MongoDB Atlas recommended for production)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/skapeta_db?retryWrites=true&w=majority
DB_NAME=skapeta_db

# Secret Key (Generate a strong random key!)
SECRET_KEY=CHANGE-THIS-TO-STRONG-SECRET-KEY-IN-PRODUCTION

# WhatsApp Number
OWNER_WHATSAPP=355693227207

# Optional: CORS Origins
# CORS_ORIGINS=https://skapeta.com,https://www.skapeta.com
